{
	"entryPoints": ["src"],
	"tsconfig": "tsconfig.json",
	"exclude": ["**/*.test.ts", "tests"],
	"excludePrivate": true,
	"excludeProtected": false,
	"excludeInternal": true,
	"readme": "none",
	"categorizeByGroup": true,
	"categoryOrder": ["downloaders", "fetcher", "pipelines", "services", "transformers", "parser", "util"],
	"sort": ["source-order"],
	"out": "docs-md",
	"plugin": ["typedoc-plugin-markdown"]
}
