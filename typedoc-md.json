{
	"entryPoints": ["packages"],
	"tsconfig": "tsconfig.json",
	"include": ["packages/**/*", "test/**/*"],
	"exclude": ["node_modules", "dist", "scripts"],
	"excludePrivate": true,
	"excludeProtected": false,
	"excludeInternal": true,
	"readme": "none",
	"categorizeByGroup": true,
	"sort": ["source-order"],
	"out": "docs-md",
	"plugin": ["typedoc-plugin-markdown"]
}
