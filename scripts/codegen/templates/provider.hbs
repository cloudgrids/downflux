import { Provider } from './Provider';
import { ProviderType } from '@app/shared';
import { InvalidUrlException } from '@app/exceptions';
import { {{ArgsName}} } from '@app/contracts';


export class {{ProviderName}}Provider extends Provider<{{ArgsName}}> {
	private readonly provider = ProviderType.{{ProviderName}}
	private readonly HOST_REGEX = /implementation$/i;

	constructor(url: string) {
		super(url);
		this.validate(url);
	}

	protected override validate(url: string): void {
		try {
			new URL(url);
		} catch {
			throw new InvalidUrlException(url, this.provider);
		}
		if (!this.isSupported(this.HOST_REGEX)) throw new InvalidUrlException(url, this.provider);
	}
}



